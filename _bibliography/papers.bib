% -----------------------------------------------------------------------------
% This file feeds your /publications page (rendered by jekyll-scholar).
% It is intentionally EMPTY of real entries — no papers are shown yet.
%
% To add a publication, copy the example below, remove the leading "% " from
% each line, change "ARTICLE" back to "@article" (or @inproceedings, @misc, ...),
% and fill in your own details. Anything that is not a real @entry is ignored.
%
% Useful optional al-folio fields:
%   abbr            -> short venue badge, e.g. NeurIPS
%   selected={true} -> also feature this paper on the homepage "selected papers"
%   bibtex_show={true} -> render a "BibTeX" button with the raw entry
%   pdf / html / arxiv / code / poster / slides / website -> link buttons
%   preview         -> thumbnail in assets/img/publication_preview/
%   abstract        -> expandable abstract text
%
% ARTICLE{mourre2026example,
%   abbr        = {NeurIPS},
%   title       = {Your Paper Title Here},
%   author      = {Mourre, Grégoire and Coauthor, Jane},
%   journal     = {Advances in Neural Information Processing Systems},
%   year        = {2026},
%   url         = {https://arxiv.org/abs/0000.00000},
%   pdf         = {your_paper.pdf},
%   abstract    = {A short summary of the paper goes here.},
%   bibtex_show = {true},
%   selected    = {true}
% }
% -----------------------------------------------------------------------------
